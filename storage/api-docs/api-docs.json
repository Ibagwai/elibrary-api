                                            "ebook",
                                            "journal",
                                            "student_project",
                                            "lecture"
                                        ]
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Introduction to Laravel"
                                    },
                                    "description": {
                                        "type": "string"
                                    },
                                    "abstract": {
                                        "type": "string"
                                    },
                                    "language": {
                                        "type": "string",
                                        "example": "en"
                                    },
                                    "published_year": {
                                        "type": "integer",
                                        "example": 2024
                                    },
                                    "access_level": {
                                        "type": "string",
